{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TrueShuffle",
  "version": "0.1.0",
  "identifier": "com.viditjain.trueshuffle",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TrueShuffle",
        "width": 1480,
        "height": 980,
        "minWidth": 1200,
        "minHeight": 800,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Music",
    "shortDescription": "Premium Spotify shuffle sessions with smarter random bursts.",
    "longDescription": "TrueShuffle is a browser-native Spotify desktop player that builds intelligent five-song random bursts with repeat avoidance and seamless handoffs.",
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
